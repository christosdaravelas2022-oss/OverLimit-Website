rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidApplication(data) {
      return data.keys().hasAll(['jobTitle', 'discordTag', 'formData', 'status', 'createdAt']) &&
             data.jobTitle is string && data.jobTitle.size() <= 200 &&
             data.discordTag is string && data.discordTag.size() <= 100 &&
             data.status in ['pending', 'accepted', 'rejected'] &&
             data.createdAt == request.time;
    }

    match /applications/{applicationId} {
      allow create: if isValidApplication(request.resource.data);
      allow read: if isSignedIn();
      allow update: if isSignedIn() && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'handledBy', 'handledAt'])
      );
    }
  }
}
